@tailwind base;
@tailwind components;
@tailwind utilities;

/* ─── Google Fonts fallback ──────────────────────────────────────────────── */
@import url('https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400&family=Manrope:wght@300;400;500;600;700&display=swap');

/* ─── CSS Custom Properties ──────────────────────────────────────────────── */
:root {
  --color-surface: #faf9f5;
  --color-primary: #003527;
  --color-primary-container: #064e3b;
  --color-secondary: #735c00;
  --color-secondary-container: #fed65b;
  --color-tertiary: #262e42;
  --color-on-surface: #1b1c1a;
  --color-outline: #707974;
  --color-outline-variant: #bfc9c3;
  --font-display: 'Newsreader', Georgia, serif;
  --font-sans: 'Manrope', system-ui, sans-serif;
}

/* ─── Base ───────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; }

html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-sans);
  background-color: var(--color-surface);
  color: var(--color-on-surface);
  line-height: 1.5;
}

/* ─── Typography Utilities ───────────────────────────────────────────────── */
@layer components {
  .font-display { font-family: var(--font-display); }

  /* Glass morphism surfaces */
  .glass {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(191, 201, 195, 0.3);
  }

  .glass-dark {
    background: rgba(0, 53, 39, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Cards */
  .card {
    @apply bg-white border border-outline-variant/40 rounded-lg shadow-card;
  }

  .card-hover {
    @apply card transition-shadow duration-200 hover:shadow-card-hover;
  }

  /* Buttons */
  .btn-primary {
    @apply bg-primary text-white font-sans font-semibold text-sm px-5 py-2.5 rounded transition-all duration-150 hover:bg-primary-container active:scale-95;
  }

  .btn-secondary {
    @apply bg-surface-lowest border border-outline-variant text-on-surface font-sans font-semibold text-sm px-5 py-2.5 rounded transition-all duration-150 hover:bg-surface-low active:scale-95;
  }

  .btn-ghost {
    @apply text-primary font-sans font-semibold text-sm px-5 py-2.5 rounded transition-all duration-150 hover:bg-primary/5;
  }

  /* Status badges */
  .badge {
    @apply inline-flex items-center gap-1 px-2 py-0.5 rounded-sm text-label-caps font-sans;
  }

  .badge-emerald {
    @apply badge bg-primary/10 text-primary;
  }

  .badge-gold {
    @apply badge bg-secondary/15 text-secondary;
  }

  .badge-navy {
    @apply badge bg-tertiary/10 text-tertiary;
  }

  .badge-error {
    @apply badge bg-error/10 text-error;
  }

  /* Input */
  .input-field {
    @apply w-full bg-transparent border-b border-outline-variant py-2 px-0 text-body-md font-sans text-on-surface
    placeholder:text-outline focus:outline-none focus:border-primary transition-colors duration-150;
  }

  .input-box {
    @apply w-full bg-surface-lowest border border-outline-variant rounded px-3 py-2 text-body-md font-sans text-on-surface
    focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all duration-150;
  }

  /* Nav link */
  .nav-link {
    @apply text-body-md font-sans text-on-surface/70 hover:text-on-surface transition-colors duration-150 cursor-pointer;
  }

  .nav-link-active {
    @apply text-body-md font-sans text-on-surface font-semibold border-b-2 border-on-surface;
  }

  /* Sidebar item */
  .sidebar-item {
    @apply flex items-center gap-3 px-4 py-2.5 rounded text-body-md font-sans text-on-surface/70 hover:bg-surface-low hover:text-on-surface transition-all duration-150 cursor-pointer;
  }

  .sidebar-item-active {
    @apply sidebar-item bg-primary text-white hover:bg-primary-container hover:text-white;
  }

  /* Section label */
  .section-label {
    @apply text-label-caps font-sans text-outline tracking-widest uppercase;
  }

  /* Metric card */
  .metric-card {
    @apply card p-6;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; height: 4px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: #bfc9c3; border-radius: 2px; }
  ::-webkit-scrollbar-thumb:hover { background: #707974; }
}

/* ─── Animations ─────────────────────────────────────────────────────────── */
@layer utilities {
  .animate-in { animation: fadeIn 0.4s ease-out forwards; }
  .animate-slide-up { animation: slideUp 0.4s ease-out forwards; }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Stagger delays */
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 300ms; }
  .delay-400 { animation-delay: 400ms; }

  /* Ivory texture overlay */
  .ivory-texture {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23000000' fill-opacity='0.012' fill-rule='evenodd'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/svg%3E");
  }
}
