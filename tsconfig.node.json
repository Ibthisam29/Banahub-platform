import axios, { AxiosInstance, InternalAxiosRequestConfig } from 'axios';

const BASE_URL = import.meta.env.VITE_API_URL || 'http://localhost:5000';

export const api: AxiosInstance = axios.create({
  baseURL: `${BASE_URL}/api`,
  timeout: 15000,
  headers: { 'Content-Type': 'application/json' },
});

// Attach token
api.interceptors.request.use((config: InternalAxiosRequestConfig) => {
  const token = localStorage.getItem('bana_access_token');
  if (token && config.headers) {
    config.headers.Authorization = `Bearer ${token}`;
  }
  return config;
});

// Refresh on 401
api.interceptors.response.use(
  (res) => res,
  async (err) => {
    if (err.response?.status === 401) {
      const refreshToken = localStorage.getItem('bana_refresh_token');
      if (refreshToken) {
        try {
          const { data } = await axios.post(`${BASE_URL}/api/auth/refresh`, { refreshToken });
          localStorage.setItem('bana_access_token', data.accessToken);
          localStorage.setItem('bana_refresh_token', data.refreshToken);
          err.config.headers.Authorization = `Bearer ${data.accessToken}`;
          return api.request(err.config);
        } catch {
          localStorage.removeItem('bana_access_token');
          localStorage.removeItem('bana_refresh_token');
          window.location.href = '/login';
        }
      }
    }
    return Promise.reject(err);
  }
);

// ─── Auth ─────────────────────────────────────────────────────────────────────
export const authService = {
  login: (email: string, password: string) =>
    api.post('/auth/login', { email, password }),
  register: (data: Record<string, string>) =>
    api.post('/auth/register', data),
  me: () => api.get('/auth/me'),
  logout: () => api.post('/auth/logout'),
};

// ─── Members (Admin) ──────────────────────────────────────────────────────────
export const memberService = {
  list: (params?: Record<string, string>) => api.get('/members', { params }),
  get: (id: string) => api.get(`/members/${id}`),
  updateStatus: (id: string, data: Record<string, string>) => api.patch(`/members/${id}/status`, data),
  stats: () => api.get('/members/stats'),
};

// ─── Mandates ─────────────────────────────────────────────────────────────────
export const mandateService = {
  list: (params?: Record<string, string>) => api.get('/mandates', { params }),
  get: (id: string) => api.get(`/mandates/${id}`),
  create: (data: unknown) => api.post('/mandates', data),
  update: (id: string, data: unknown) => api.patch(`/mandates/${id}`, data),
};

// ─── Programs ─────────────────────────────────────────────────────────────────
export const programService = {
  list: (params?: Record<string, string>) => api.get('/programs', { params }),
  get: (id: string) => api.get(`/programs/${id}`),
  registerInterest: (programId: string) => api.post('/programs/register-interest', { programId }),
};

// ─── Portfolio ────────────────────────────────────────────────────────────────
export const portfolioService = {
  overview: () => api.get('/portfolio/overview'),
};

// ─── Admin ────────────────────────────────────────────────────────────────────
export const adminService = {
  dashboard: () => api.get('/admin/dashboard'),
};
