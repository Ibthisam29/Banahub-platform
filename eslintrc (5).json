import { useState } from 'react';
import { useNavigate } from 'react-router-dom';
import { CheckCircle, Circle, ArrowRight } from 'lucide-react';
import clsx from 'clsx';

const STEPS = [
  { id: 0, label: 'Welcome' },
  { id: 1, label: 'Company Profile' },
  { id: 2, label: 'Institutional Vetting' },
  { id: 3, label: 'Submission Complete' },
];

function StepWelcome({ onNext }: { onNext: () => void }) {
  return (
    <div className="animate-slide-up">
      <div className="w-16 h-16 bg-primary rounded-xl flex items-center justify-center mb-8">
        <span className="text-white text-2xl font-display font-bold">B</span>
      </div>
      <p className="section-label mb-3">Onboarding · Step 1 of 3</p>
      <h1 className="font-display font-semibold text-headline-lg text-on-surface mb-3">Welcome to BANAHub</h1>
      <p className="text-body-lg font-sans text-on-surface/60 mb-8 max-w-md">
        You're joining an exclusive network of institutional leaders, sovereign capital partners, and cross-border expansion experts. This brief onboarding ensures we match you with the right mandates, programs, and connections.
      </p>
      <div className="flex flex-col gap-3 mb-10">
        {[
          'Verified institutional access to exclusive deal mandates',
          'Curated program and summit invitations',
          'AI-powered mandate matching via Leya',
          'Direct access to sovereign and family office networks',
        ].map((f) => (
          <div key={f} className="flex items-start gap-3">
            <CheckCircle size={16} className="text-primary mt-0.5 flex-shrink-0" />
            <span className="text-body-md font-sans text-on-surface/70">{f}</span>
          </div>
        ))}
      </div>
      <button onClick={onNext} className="btn-primary flex items-center gap-2">
        Begin Onboarding <ArrowRight size={16} />
      </button>
    </div>
  );
}

function StepCompanyProfile({ onNext }: { onNext: () => void }) {
  return (
    <div className="animate-slide-up">
      <p className="section-label mb-3">Onboarding · Step 2 of 3</p>
      <h1 className="font-display font-semibold text-headline-lg text-on-surface mb-2">Company Profile</h1>
      <p className="text-body-md font-sans text-on-surface/60 mb-8">Tell us about your institution to enable mandate matching and network introductions.</p>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        {[
          { label: 'Legal Entity Name', placeholder: 'Full registered name' },
          { label: 'Registration Number', placeholder: 'e.g. UEN / CRN' },
          { label: 'Country of Incorporation', placeholder: 'Singapore' },
          { label: 'Primary Business Address', placeholder: 'Registered address' },
        ].map(({ label, placeholder }) => (
          <div key={label}>
            <label className="section-label block mb-2">{label}</label>
            <input type="text" placeholder={placeholder} className="input-box w-full" />
          </div>
        ))}
      </div>

      <div className="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div>
          <label className="section-label block mb-2">Institution Type</label>
          <select className="input-box w-full">
            {['Family Office', 'Sovereign Wealth Fund', 'Private Equity', 'Venture Capital', 'Corporate Treasury', 'Asset Manager'].map(t => (
              <option key={t}>{t}</option>
            ))}
          </select>
        </div>
        <div>
          <label className="section-label block mb-2">AUM Range</label>
          <select className="input-box w-full">
            {['< $50M', '$50M – $250M', '$250M – $1B', '$1B – $5B', '$5B+'].map(r => (
              <option key={r}>{r}</option>
            ))}
          </select>
        </div>
      </div>

      <div className="mb-8">
        <label className="section-label block mb-2">Investment Focus</label>
        <div className="flex flex-wrap gap-2">
          {['SEA Fintech', 'Gulf Infrastructure', 'North Asia Tech', 'Real Estate', 'ESG / Green', 'Private Credit', 'Direct Equity'].map(sector => (
            <button key={sector} className="px-3 py-1.5 rounded-full border border-outline-variant text-body-md font-sans text-on-surface/70 hover:border-primary hover:text-primary hover:bg-primary/5 transition-all duration-150">
              {sector}
            </button>
          ))}
        </div>
      </div>

      <button onClick={onNext} className="btn-primary flex items-center gap-2">
        Continue <ArrowRight size={16} />
      </button>
    </div>
  );
}

function StepVetting({ onNext }: { onNext: () => void }) {
  return (
    <div className="animate-slide-up">
      <p className="section-label mb-3">Onboarding · Step 3 of 3</p>
      <h1 className="font-display font-semibold text-headline-lg text-on-surface mb-2">Institutional Vetting</h1>
      <p className="text-body-md font-sans text-on-surface/60 mb-8">
        BANAHub conducts a thorough institutional verification to maintain the integrity of our network. All information is handled under strict confidentiality.
      </p>

      <div className="flex flex-col gap-5 mb-8">
        {[
          { label: 'Primary Contact Full Name', placeholder: 'Legal name of authorized representative' },
          { label: 'Direct Phone Number', placeholder: '+65 XXXX XXXX', type: 'tel' },
          { label: 'LinkedIn Profile URL', placeholder: 'https://linkedin.com/in/...', type: 'url' },
        ].map(({ label, placeholder, type = 'text' }) => (
          <div key={label}>
            <label className="section-label block mb-2">{label}</label>
            <input type={type} placeholder={placeholder} className="input-box w-full" />
          </div>
        ))}

        {/* Upload fields */}
        {['KYC / Passport / NRIC', 'Proof of Institution (UEN / CRN certificate)'].map((doc) => (
          <div key={doc}>
            <label className="section-label block mb-2">{doc}</label>
            <div className="border-2 border-dashed border-outline-variant rounded-lg p-6 text-center hover:border-primary hover:bg-primary/[0.02] transition-all cursor-pointer">
              <p className="text-body-md font-sans text-outline">Drop file or <span className="text-primary font-semibold">browse</span></p>
              <p className="text-label-caps text-outline/70 mt-1">PDF, JPG, PNG · Max 10MB</p>
            </div>
          </div>
        ))}

        {/* Consent */}
        <label className="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" className="mt-0.5 accent-primary" />
          <span className="text-body-md font-sans text-on-surface/70">
            I confirm all information provided is accurate and I consent to BANAHub conducting institutional verification checks in accordance with our{' '}
            <span className="text-primary underline">Privacy Policy</span>.
          </span>
        </label>
      </div>

      <button onClick={onNext} className="btn-primary flex items-center gap-2">
        Submit Application <ArrowRight size={16} />
      </button>
    </div>
  );
}

function StepComplete() {
  const navigate = useNavigate();
  return (
    <div className="animate-slide-up text-center max-w-md mx-auto">
      <div className="w-20 h-20 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <CheckCircle size={36} className="text-primary" />
      </div>
      <p className="section-label mb-3">Submission Complete</p>
      <h1 className="font-display font-semibold text-headline-lg text-on-surface mb-3">Application Received</h1>
      <p className="text-body-lg font-sans text-on-surface/60 mb-8">
        Your institutional application has been submitted. Our team will review your profile and respond within 2 business days. You'll receive a priority access notification via email.
      </p>
      <div className="card p-5 text-left mb-8">
        <p className="section-label mb-3">What happens next</p>
        {[
          'Our compliance team reviews your KYC documents',
          'Institutional verification against our partner network',
          'Tier assignment (Founding or Standard)',
          'Welcome briefing scheduled with your Relationship Manager',
        ].map((s, i) => (
          <div key={s} className="flex items-start gap-3 mb-3 last:mb-0">
            <span className="w-5 h-5 bg-surface-high rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
              <span className="text-label-caps text-on-surface/60">{i + 1}</span>
            </span>
            <span className="text-body-md font-sans text-on-surface/70">{s}</span>
          </div>
        ))}
      </div>
      <button onClick={() => navigate('/dashboard')} className="btn-primary w-full">
        Go to Dashboard
      </button>
    </div>
  );
}

export default function OnboardingPage() {
  const [step, setStep] = useState(0);

  return (
    <div className="min-h-screen bg-surface ivory-texture flex">
      {/* Sidebar */}
      <aside className="hidden lg:flex w-64 bg-surface-lowest border-r border-outline-variant/20 flex-col p-8">
        <p className="text-title-lg font-display font-semibold text-on-surface mb-10">BANAHub</p>
        <nav className="flex flex-col gap-2">
          {STEPS.map((s) => (
            <div key={s.id} className={clsx(
              'flex items-center gap-3 px-3 py-2.5 rounded text-body-md font-sans transition-all',
              step === s.id ? 'bg-primary text-white' : step > s.id ? 'text-on-surface/70' : 'text-on-surface/40'
            )}>
              {step > s.id
                ? <CheckCircle size={16} className="text-primary" />
                : step === s.id
                ? <Circle size={16} className="text-white fill-white/30" />
                : <Circle size={16} className="text-on-surface/30" />
              }
              {s.label}
            </div>
          ))}
        </nav>
      </aside>

      {/* Content */}
      <main className="flex-1 flex items-start justify-center p-8 lg:p-16 overflow-y-auto">
        <div className="w-full max-w-2xl">
          {step === 0 && <StepWelcome onNext={() => setStep(1)} />}
          {step === 1 && <StepCompanyProfile onNext={() => setStep(2)} />}
          {step === 2 && <StepVetting onNext={() => setStep(3)} />}
          {step === 3 && <StepComplete />}
        </div>
      </main>
    </div>
  );
}
