import { Router } from 'express';
import { authenticate, requireRole } from '../utils/auth.middleware';

// ─── Mandates ─────────────────────────────────────────────────────────────────
export const mandateRouter = Router();
mandateRouter.use(authenticate);
mandateRouter.get('/', async (_req, res) => {
  res.json({ mandates: [], total: 0, page: 1 });
});
mandateRouter.get('/:id', async (req, res) => {
  res.json({ id: req.params.id });
});
mandateRouter.post('/', requireRole('admin'), async (_req, res) => {
  res.status(201).json({ message: 'Mandate created' });
});
mandateRouter.patch('/:id', requireRole('admin'), async (req, res) => {
  res.json({ id: req.params.id, updated: true });
});

// ─── Programs ─────────────────────────────────────────────────────────────────
export const programRouter = Router();
programRouter.get('/', async (_req, res) => {
  res.json({ programs: [], total: 0 });
});
programRouter.get('/:id', async (req, res) => {
  res.json({ id: req.params.id });
});
programRouter.post('/register-interest', authenticate, async (_req, res) => {
  res.json({ registered: true });
});
programRouter.post('/', authenticate, requireRole('admin'), async (_req, res) => {
  res.status(201).json({ message: 'Program created' });
});

